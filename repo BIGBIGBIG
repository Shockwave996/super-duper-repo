<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Ultimate Dev Universe</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
/* ===== GLOBAL UI ===== */
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #0f0f1a;
    color: white;
    overflow-x: hidden;
}

header {
    padding: 20px;
    text-align: center;
    background: linear-gradient(90deg,#6a00ff,#00d4ff);
    font-size: 24px;
    font-weight: bold;
}

nav {
    display: flex;
    justify-content: center;
    gap: 10px;
    padding: 10px;
    background: #111;
    position: sticky;
    top: 0;
}

nav button {
    padding: 10px;
    border: none;
    cursor: pointer;
    background: #222;
    color: white;
    border-radius: 8px;
}

nav button:hover {
    background: #444;
}

.section {
    display: none;
    padding: 20px;
}

.active {
    display: block;
}

/* ===== CARDS ===== */
.card {
    background: rgba(255,255,255,0.05);
    padding: 15px;
    margin: 10px;
    border-radius: 12px;
    backdrop-filter: blur(10px);
}

/* ===== BUTTONS ===== */
.btn {
    padding: 10px;
    border: none;
    background: #6a00ff;
    color: white;
    border-radius: 8px;
    cursor: pointer;
}

/* ===== CANVAS BACKGROUND ===== */
canvas {
    position: fixed;
    top: 0;
    left: 0;
    z-index: -1;
}
</style>
</head>

<body>

<canvas id="bg"></canvas>

<header>🚀 Ultimate Dev Universe</header>

<nav>
<button onclick="show('home')">Home</button>
<button onclick="show('tools')">Tools</button>
<button onclick="show('games')">Games</button>
<button onclick="show('editor')">Code Editor</button>
</nav>

<!-- ===== HOME ===== -->
<div id="home" class="section active">
    <div class="card">
        <h2>Welcome 😎</h2>
        <p>This is your all-in-one dev universe with tools, games, and UI systems.</p>
    </div>

    <div class="card">
        <h3>Quick Clicker Game</h3>
        <p>Clicks: <span id="clicks">0</span></p>
        <button class="btn" onclick="clicker()">Click me</button>
    </div>
</div>

<!-- ===== TOOLS ===== -->
<div id="tools" class="section">
    <div class="card">
        <h2>Random Color Generator</h2>
        <button class="btn" onclick="color()">Generate</button>
        <div id="colorBox" style="height:100px;margin-top:10px;"></div>
    </div>

    <div class="card">
        <h2>Text Reverser</h2>
        <input id="text" placeholder="type here">
        <button class="btn" onclick="reverse()">Reverse</button>
        <p id="out"></p>
    </div>
</div>

<!-- ===== GAMES ===== -->
<div id="games" class="section">
    <div class="card">
        <h2>Mini Snake Game</h2>
        <canvas id="game" width="300" height="300" style="background:black;"></canvas>
        <p>Use arrow keys</p>
    </div>
</div>

<!-- ===== CODE EDITOR ===== -->
<div id="editor" class="section">
    <div class="card">
        <h2>Live HTML Editor</h2>
        <textarea id="code" style="width:100%;height:150px;">
<h1>Hello World</h1>
<p>Edit me!</p>
        </textarea>
        <button class="btn" onclick="run()">Run</button>
    </div>

    <div class="card" id="output"></div>
</div>

<script>
/* ===== NAV SYSTEM ===== */
function show(id){
    document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
    document.getElementById(id).classList.add('active');
}

/* ===== CLICKER GAME ===== */
let clicks = 0;
function clicker(){
    clicks++;
    document.getElementById("clicks").innerText = clicks;
}

/* ===== COLOR TOOL ===== */
function color(){
    let c = "#"+Math.floor(Math.random()*16777215).toString(16);
    document.getElementById("colorBox").style.background = c;
}

/* ===== TEXT REVERSE ===== */
function reverse(){
    let t = document.getElementById("text").value;
    document.getElementById("out").innerText = t.split("").reverse().join("");
}

/* ===== LIVE EDITOR ===== */
function run(){
    let code = document.getElementById("code").value;
    document.getElementById("output").innerHTML = code;
}

/* ===== SIMPLE SNAKE GAME ===== */
let canvas = document.getElementById("game");
let ctx = canvas.getContext("2d");

let snake = [{x:10,y:10}];
let dir = "right";
let food = {x:5,y:5};

document.addEventListener("keydown",e=>{
    if(e.key=="ArrowUp")dir="up";
    if(e.key=="ArrowDown")dir="down";
    if(e.key=="ArrowLeft")dir="left";
    if(e.key=="ArrowRight")dir="right";
});

function game(){
    let head = {...snake[0]};

    if(dir=="right")head.x++;
    if(dir=="left")head.x--;
    if(dir=="up")head.y--;
    if(dir=="down")head.y++;

    if(head.x==food.x && head.y==food.y){
        food={x:Math.floor(Math.random()*20),y:Math.floor(Math.random()*20)};
    } else {
        snake.pop();
    }

    snake.unshift(head);

    ctx.fillStyle="black";
    ctx.fillRect(0,0,300,300);

    ctx.fillStyle="red";
    ctx.fillRect(food.x*15,food.y*15,15,15);

    ctx.fillStyle="lime";
    snake.forEach(s=>{
        ctx.fillRect(s.x*15,s.y*15,15,15);
    });
}

setInterval(game,150);

/* ===== BACKGROUND PARTICLES ===== */
let c = document.getElementById("bg");
let x = c.getContext("2d");
c.width = window.innerWidth;
c.height = window.innerHeight;

let particles = [];
for(let i=0;i<80;i++){
    particles.push({
        x:Math.random()*c.width,
        y:Math.random()*c.height,
        r:Math.random()*2
    });
}

function bg(){
    x.fillStyle="#0f0f1a";
    x.fillRect(0,0,c.width,c.height);

    x.fillStyle="#6a00ff";
    particles.forEach(p=>{
        p.y+=1;
        if(p.y>c.height)p.y=0;
        x.beginPath();
        x.arc(p.x,p.y,p.r,0,Math.PI*2);
        x.fill();
    });

    requestAnimationFrame(bg);
}
bg();
</script>

</body>
</html>
